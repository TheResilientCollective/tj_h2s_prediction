# Build context: repo root (Railway sets this automatically)
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Install uv for fast dependency resolution
RUN pip install --no-cache-dir uv==0.4.*

# Copy dashboard package manifest and install deps
COPY dashboard/pyproject.toml dashboard/uv.lock ./
RUN uv sync --frozen --no-dev

# Copy dashboard source
COPY dashboard/ /app/dashboard/

EXPOSE 5006

# Railway injects PORT; fall back to 5006 locally.
# --address 0.0.0.0 is required for Railway's proxy to reach the server.
# --allow-websocket-origin=* accepts websockets behind Railway's proxy.
ENV PORT=5006
CMD ["sh", "-c", "uv run panel serve dashboard/app.py --address 0.0.0.0 --port ${PORT} --allow-websocket-origin=*"]
